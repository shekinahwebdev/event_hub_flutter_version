generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  id              BigInt          @id @default(autoincrement())
  title           String
  description     String
  location        String
  total_slots     Int
  remaining_slots Int
  registrations   registrations[]
}

model registrations {
  id            BigInt    @id @default(autoincrement())
  user_id       BigInt?
  event_id      BigInt?
  registered_at DateTime? @default(now()) @db.Timestamp(6)
  events        events?   @relation(fields: [event_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_event")
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user")

  @@unique([user_id, event_id])
}

model users {
  id            BigInt          @id @default(autoincrement())
  name          String          @unique
  email         String          @unique
  password      String
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  registrations registrations[]
}
